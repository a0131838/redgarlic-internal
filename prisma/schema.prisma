generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum EmployeeRole {
  OWNER
  ADMIN
  STAFF
}

enum SharedFileStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model Employee {
  id           String      @id @default(uuid())
  email        String      @unique
  name         String
  role         EmployeeRole @default(STAFF)
  isActive     Boolean     @default(true)
  passwordHash String?
  passwordSalt String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  sessions     AuthSession[]
  uploadedFiles SharedFile[]       @relation("SharedFileUploader")
  fileAudits    SharedFileAudit[]  @relation("SharedFileAuditActor")
}

model AuthSession {
  id        String   @id @default(uuid())
  token     String   @unique
  employeeId String
  expiresAt DateTime
  createdAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([expiresAt])
}

model FileCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folders SharedFolder[]
  files   SharedFile[]
}

model SharedFolder {
  id         String   @id @default(uuid())
  name       String
  categoryId String
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category FileCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  parent   SharedFolder? @relation("SharedFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children SharedFolder[] @relation("SharedFolderTree")
  files    SharedFile[]

  @@unique([categoryId, parentId, name])
  @@index([categoryId, parentId, createdAt])
}

model SharedFile {
  id               String           @id @default(uuid())
  title            String
  categoryId       String
  folderId         String?
  status           SharedFileStatus @default(ACTIVE)
  filePath         String
  originalFileName String
  mimeType         String?
  fileSizeBytes    Int
  remarks          String?
  uploadedById     String
  archivedAt       DateTime?
  archivedByEmail  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  category FileCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  folder   SharedFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploader Employee      @relation("SharedFileUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  audits   SharedFileAudit[]

  @@index([categoryId, status, createdAt])
  @@index([folderId, status, createdAt])
  @@index([uploadedById, createdAt])
}

model SharedFileAudit {
  id        String   @id @default(uuid())
  fileId     String?
  actorId    String
  action     String
  note       String?
  fileTitleSnapshot String?
  createdAt  DateTime @default(now())

  file  SharedFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)
  actor Employee   @relation("SharedFileAuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([fileId, createdAt])
  @@index([actorId, createdAt])
}
