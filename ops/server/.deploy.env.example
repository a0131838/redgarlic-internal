# Copy to: ops/server/.deploy.env
# Fill values before running scripts.

APP_NAME=redgarlic-internal
APP_DIR=/opt/redgarlic-internal
REPO_URL=https://github.com/YOUR_ORG/redgarlic-internal.git
BRANCH=main
DEPLOY_USER=deploy
APP_PORT=3001
DOMAIN=redgarlicai.com
LETSENCRYPT_EMAIL=ops@redgarlicai.com

# Required app env
NEXT_PUBLIC_APP_URL=https://redgarlicai.com
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/redgarlic_internal?sslmode=require
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/redgarlic_internal?sslmode=require
SESSION_COOKIE_NAME=redgarlic_session
SHARED_FILE_STORAGE_DRIVER=local
SHARED_FILE_S3_BUCKET=
SHARED_FILE_S3_REGION=ap-singapore
SHARED_FILE_S3_ENDPOINT=
SHARED_FILE_S3_FORCE_PATH_STYLE=false
SHARED_FILE_S3_ACCESS_KEY_ID=
SHARED_FILE_S3_SECRET_ACCESS_KEY=

# Deployment safety
CLEAN_UNTRACKED=true
SKIP_RELEASE_DOC_CHECK=false
ALLOW_LOCAL_DB_IN_PROD=false
